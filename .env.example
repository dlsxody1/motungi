# ─────────────────────────────────────────────────────────────
# 모퉁이 Corner — 환경변수 예시. 복사해서 .env 로 채우세요.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# Supabase (프로젝트 대시보드 → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 서버 전용(절대 클라이언트 노출 금지). Edge Function / 배치 적재용.
SUPABASE_SERVICE_ROLE_KEY=

# Expo 앱에서 참조 (EXPO_PUBLIC_ 접두어만 클라이언트 노출됨)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# ── 데이터 소스 (§7) — 발급 후 채움 ──
# 소상공인시장진흥공단 상가(상권)정보 API
DATA_GO_KR_API_KEY=
# 온통청년 청년정책 API
YOUTH_POLICY_API_KEY=
# 제휴 피드
COUPANG_PARTNERS_ACCESS_KEY=
COUPANG_PARTNERS_SECRET_KEY=
