# ─────────────────────────────────────────────────────────────
# 모퉁이 Corner — 환경변수 예시. 복사해서 .env 로 채우세요.
#   cp .env.example .env
# 기획: "퇴근하고 뭐하지?" (docs/PIVOT-afterwork.md)
# 소스 설계: docs/DATA-SOURCES.md
# ─────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
# 프로젝트 대시보드 → Settings → API Keys (신규 키 체계)
NEXT_PUBLIC_SUPABASE_URL=
# Publishable key (sb_publishable_...) — 공개 가능, 브라우저 노출 OK
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Secret key (sb_secret_...) — 서버 전용(절대 클라이언트 노출 금지). Edge Function / 배치 적재용.
SUPABASE_SECRET_KEY=

# Expo 앱에서 참조 (EXPO_PUBLIC_ 접두어만 클라이언트 노출됨)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ── data.go.kr (공용 인증키 1개) ──────────────────────────────
# 아래 3개 API는 동일한 활용신청 인증키를 공유한다.
#   - 소상공인 상권정보   https://apis.data.go.kr/B553077/api/open/sdsc2
#   - 두루누비 걷기길     https://apis.data.go.kr/B551011/Durunubi
#   - 한눈에보는문화정보  https://apis.data.go.kr/B553457/cultureinfo
# 포털 제공 Decoding 키를 넣는다(코드에서 encodeURIComponent 처리).
# ⚠️ 서버 전용 — 클라이언트/NEXT_PUBLIC_ 금지. 배치 적재에서만 사용.
DATA_GO_KR_SERVICE_KEY=

# ── 서울 열린데이터광장 (별도 인증키) ──────────────────────────
# 서울시 일자리플러스센터 채용정보 (OA-13341)
#   http://openapi.seoul.go.kr:8088/{KEY}/xml/GetJobInfo/{start}/{end}/
# ⚠️ 서버 전용.
SEOUL_OPENAPI_KEY=

# ── 위치 (역지오코딩) ─────────────────────────────────────────
# Kakao Local coord2regioncode — 좌표→행정동.
# ⚠️ 서버 전용(프록시). REST 키가 클라에 노출되면 안 됨.
KAKAO_REST_API_KEY=

# ── 제휴 (보류) ───────────────────────────────────────────────
# COUPANG_PARTNERS_ACCESS_KEY=
# COUPANG_PARTNERS_SECRET_KEY=
